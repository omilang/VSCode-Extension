{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(func|if|for|while|try|catch|final|match|case|async\\s+[A-Za-z_][A-Za-z0-9_]*\\s*(?:\\([^)]*\\))?\\s*:)\\b",
      "end": "^\\s*end\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(func|if|elif|else|try|catch|final|match|case|for|while)\\b.*$|^\\s*async\\s+[A-Za-z_][A-Za-z0-9_]*\\s*(?:\\([^)]*\\))?\\s*:\\s*$",
    "decreaseIndentPattern": "^\\s*(end|elif|else|catch|final|case)\\b"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
