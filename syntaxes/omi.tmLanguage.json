{
  "$schema": "https://json.schemastore.org/tmlanguage.json",
  "name": "Omi",
  "scopeName": "source.omi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#keywords" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#module-access" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.omi",
          "match": "//.*$"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "match": "(@)(import)\\s+(\"[^\"]*\")\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.import.omi" },
            "2": { "name": "keyword.control.import.omi" },
            "3": { "name": "string.quoted.double.omi" },
            "4": { "name": "keyword.control.import.omi" },
            "5": { "name": "entity.name.namespace.omi" }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.omi" },
            "2": { "name": "entity.name.function.omi" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.omi" }
          }
        }
      ]
    },
    "module-access": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.namespace.omi" },
            "2": { "name": "variable.other.property.omi" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.omi",
          "match": "\\b(if|elif|else|for|to|step|while|end|return|continue|break)\\b"
        },
        {
          "name": "keyword.declaration.omi",
          "match": "\\b(var|func)\\b"
        },
        {
          "name": "keyword.operator.logical.omi",
          "match": "\\b(and|or|is|isnt)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.omi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.omi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.omi",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.omi",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.omi",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.omi",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.omi",
          "match": "\\+|-|\\*|/|\\^"
        },
        {
          "name": "keyword.operator.arrow.omi",
          "match": "->"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.omi",
          "match": "\\b(true|TRUE)\\b"
        },
        {
          "name": "constant.language.boolean.false.omi",
          "match": "\\b(false|FALSE)\\b"
        },
        {
          "name": "constant.language.null.omi",
          "match": "\\b(null|NULL)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.omi",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
