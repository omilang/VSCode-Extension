{
  "$schema": "https://json.schemastore.org/tmlanguage.json",
  "name": "Omi",
  "scopeName": "source.omi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#keywords" },
    { "include": "#type-annotation" },
    { "include": "#type-keywords" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#module-function-call" },
    { "include": "#module-access" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.omi",
          "match": "//.*$"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "comment": "@import \"path\" as alias",
          "match": "(@)(import)\\s+(\"[^\"]*\")\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.directive.omi" },
            "2": { "name": "keyword.control.directive.omi" },
            "3": { "name": "string.quoted.double.omi" },
            "4": { "name": "keyword.control.directive.omi" },
            "5": { "name": "entity.name.namespace.omi" }
          }
        },
        {
          "comment": "@use flag",
          "match": "(@)(use)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.directive.omi" },
            "2": { "name": "keyword.control.directive.omi" },
            "3": { "name": "entity.other.attribute-name.omi" }
          }
        },
        {
          "comment": "@set name as value — module.func alias",
          "match": "(@)(set)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.directive.omi" },
            "2": { "name": "keyword.control.directive.omi" },
            "3": { "name": "entity.name.namespace.omi" },
            "4": { "name": "entity.name.function.omi" },
            "5": { "name": "keyword.control.directive.omi" },
            "6": { "name": "entity.name.function.omi" }
          }
        },
        {
          "comment": "@set NAME as value",
          "match": "(@)(set)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+(as)\\b",
          "captures": {
            "1": { "name": "keyword.control.directive.omi" },
            "2": { "name": "keyword.control.directive.omi" },
            "3": { "name": "variable.other.constant.omi" },
            "4": { "name": "keyword.control.directive.omi" }
          }
        }
      ]
    },
    "type-annotation": {
      "patterns": [
        {
          "comment": "Typed array annotations: [int], [int | bool], [string?]",
          "match": "\\[([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)?\\??(?:\\s*\\|\\s*[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)?\\??)*)\\]",
          "captures": {
            "1": { "name": "entity.name.type.omi" }
          }
        },
        {
          "comment": "Type annotations: <int?>, <string | bool>, <every>, <int | null>, etc. — ? is part of the type",
          "match": "<([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)?\\??(?:\\s*\\|\\s*(?:[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)?\\??|\"[^\"]*\"))*)>",
          "captures": {
            "1": { "name": "entity.name.type.omi" }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "comment": "func<type> name or async func<type> name",
          "match": "\\b(?:((async)\\s+))?(func)(?:<[^>]*>)?\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "2": { "name": "keyword.control.omi" },
            "3": { "name": "keyword.declaration.function.omi" },
            "4": { "name": "entity.name.function.omi" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.omi" }
          }
        }
      ]
    },
    "module-function-call": {
      "patterns": [
        {
          "comment": "module.func( — function call on a module",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.namespace.omi" },
            "2": { "name": "entity.name.function.call.omi" }
          }
        }
      ]
    },
    "module-access": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.namespace.omi" },
            "2": { "name": "variable.other.property.omi" }
          }
        }
      ]
    },
    "type-keywords": {
      "patterns": [
        {
          "comment": "Built-in type names used outside angle brackets (e.g. in type aliases, annotations)",
          "name": "storage.type.omi",
          "match": "\\b(int|float|number|string|bool|array|dict|func|call|future|void|null|every)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.omi",
<<<<<<< Updated upstream
          "match": "\\b(if|elif|else|for|to|step|while|try|catch|match|case|end|return|continue|break)\\b"
=======
          "match": "\\b(if|elif|else|try|catch|final|match|case|for|to|step|while|async|end|return|continue|break)\\b"
>>>>>>> Stashed changes
        },
        {
          "name": "keyword.declaration.omi",
          "match": "\\b(var|const|async|func|type|enum|trait)\\b"
        },
        {
          "name": "keyword.operator.logical.omi",
          "match": "\\b(and|or|is|isnt)\\b"
        },
        {
          "name": "keyword.other.omi",
          "match": "\\b(as|use|set)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.omi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.omi",
              "match": "\\\\."
            },
            {
              "comment": "F-string: ~(expression)",
              "name": "meta.interpolation.omi",
              "begin": "~\\(",
              "end": "\\)",
              "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.omi" } },
              "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.omi" } },
              "patterns": [
                { "include": "#numbers" },
                { "include": "#constants" },
                { "include": "#operators" },
                { "include": "#variables" }
              ]
            },
            {
              "comment": "F-string: ~identifier",
              "name": "meta.interpolation.omi",
              "match": "~[a-zA-Z_][a-zA-Z0-9_]*",
              "captures": { "0": { "name": "variable.other.readwrite.omi" } }
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.omi",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.omi",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.omi",
          "match": "->"
        },
        {
          "name": "keyword.operator.nullcoal.omi",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.comparison.omi",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.omi",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.omi",
          "match": "\\+|-|\\*|/|\\^"
        },
        {
          "name": "keyword.operator.nullable.omi",
          "match": "(?<=\\w)\\?"
        },
        {
          "name": "keyword.operator.ternary.omi",
          "match": "(?<!\\\\)~"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.omi",
          "match": "\\b(true|TRUE)\\b"
        },
        {
          "name": "constant.language.boolean.false.omi",
          "match": "\\b(false|FALSE)\\b"
        },
        {
          "name": "constant.language.null.omi",
          "match": "\\b(null|NULL)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.omi",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
